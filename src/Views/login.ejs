<h1>Iniciar sesion</h1>
<div class="log-in">
    <form action="/login" method="POST">

        <% if(error){ %>
            <span name="error"><%= error %></span>
        <% } %>

        <label>Correo</label>
        <input type="email" name="email" placeholder="Ingresa tu correo" required>

        <label>Contraseña</label>
        <input type="password" name="clave" placeholder="Ingresa tu contraseña" required>

        <button type="submit">Enviar</button>

    </form>
</div>
<p>¿No tienes una cuenta? Registrate aqui: <a href="/Registro" >Registrate!!</a></p>


<style>
    body {
        font-family: Arial, sans-serif;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    h1 {
        margin-top: 40px;
        text-align: center;
    }

    .log-in {
        width: 100%;
        display: flex;
        justify-content: center;
        margin-top: 20px;
    }

    form {
        display: flex;
        flex-direction: column;
        width: 320px;
        gap: 10px;
    }

    label {
        font-size: 14px;
    }

    input,
    button {
        padding: 8px;
        font-size: 14px;
    }

    button,
    input[type="submit"] {
        cursor: pointer;
        margin-top: 10px;
    }

    p {
        margin-top: 20px;
        text-align: center;
    }
</style>