<h1>Editar tarea</h1>
<form action="/tarea/edit/<%= id %>" method="POST">
    <input type="text" name="titulo" placeholder="Titulo" value="<%= titulo %>" required>
        <textarea name="contenido" rows="5" cols="40" placeholder="Descripción" required ><%= contenido %></textarea>
        <input type="submit" value="Editar tarea">
</form>

<style>
    body {
        font-family: Arial, sans-serif;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    h1 {
        margin-top: 40px;
        text-align: center;
    }


    form {
        display: flex;
        flex-direction: column;
        width: 320px;
        gap: 10px;
    }
</style>